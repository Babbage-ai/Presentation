# DisplayFlow Pi runtime configuration
# Adjust the API base URL to match your deployment.

DISPLAYFLOW_API_BASE_URL=https://babbage-ai.co.uk/Present
DISPLAYFLOW_INTERFACE=wlan0
DISPLAYFLOW_AP_COUNTRY=GB
DISPLAYFLOW_AP_CHANNEL=6
DISPLAYFLOW_AP_HOST=192.168.4.1
DISPLAYFLOW_AP_CIDR=192.168.4.1/24
DISPLAYFLOW_AP_NETWORK_CIDR=192.168.4.0/24
DISPLAYFLOW_AP_DHCP_RANGE=192.168.4.50,192.168.4.150,255.255.255.0,12h
DISPLAYFLOW_FAILURE_THRESHOLD=3
DISPLAYFLOW_CONNECT_TIMEOUT=60
DISPLAYFLOW_CONNECTIVITY_URL=https://connectivitycheck.gstatic.com/generate_204
DISPLAYFLOW_PLAYER_PORT=8080
DISPLAYFLOW_SETUP_PORT=80
DISPLAYFLOW_REFRESH_INTERVAL=300
DISPLAYFLOW_HEARTBEAT_INTERVAL=60
DISPLAYFLOW_CACHE_NAMESPACE_PREFIX=screen
